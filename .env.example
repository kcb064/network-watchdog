# Copy to .env and fill in. These are referenced from config/config.yaml
# via ${VAR} interpolation — secrets never live in the YAML itself.

TZ=America/New_York

# --- ntfy ---------------------------------------------------------------
# Pick a long, unguessable topic name — anyone who knows it can read alerts.
NTFY_TOPIC=netwatch-CHANGE-ME-a8f3k2
# Only needed for a protected/self-hosted server:
NTFY_TOKEN=

# --- UniFi --------------------------------------------------------------
# Create a dedicated LOCAL admin on your console (not a ui.com cloud account):
# UniFi OS → Admins & Users → Add Admin → "Restrict to local access only".
# Needs Network app admin rights if you want device-restart remediation.
UNIFI_USERNAME=
UNIFI_PASSWORD=

# --- Home Assistant -----------------------------------------------------
# Profile → Security → Long-lived access tokens → Create token
HA_TOKEN=

# --- AdGuard Home --------------------------------------------------------
ADGUARD_USERNAME=
ADGUARD_PASSWORD=

# --- TrueNAS -------------------------------------------------------------
# TrueNAS UI → top-right user icon → API Keys → Add
TRUENAS_API_KEY=

# --- Watchdog dashboard ----------------------------------------------------
# Optional HTTP basic auth for the dashboard (username is "admin"):
WATCHDOG_PASSWORD=
