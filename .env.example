# Network Watchdog settings — in Dockge, paste this into the .env panel and
# fill in what you actually run. Setting a service's variables turns its
# monitoring ON; leave a service commented out to skip it.
# WAN and Docker monitoring are always on (DOCKER_ENABLED=false to opt out).

TZ=America/New_York

# --- ntfy push notifications ----------------------------------------------
# The topic doubles as a password — pick something long and unguessable.
NTFY_TOPIC=netwatch-CHANGE-ME-a8f3k2
#NTFY_SERVER=https://ntfy.sh
#NTFY_TOKEN=

# --- Approve/Deny buttons -----------------------------------------------------
# URL your phone can reach (LAN/VPN). Without it, approvals happen on the
# dashboard instead of in the notification.
PUBLIC_URL=http://192.168.1.2:8787

# --- UniFi -----------------------------------------------------------------
# Create a dedicated LOCAL admin: UniFi OS → Admins & Users → Add Admin →
# "Restrict to local access only" (cloud SSO accounts won't work).
#UNIFI_URL=https://192.168.1.1
#UNIFI_USERNAME=
#UNIFI_PASSWORD=

# --- Home Assistant -----------------------------------------------------------
# Token: HA → Profile → Security → Long-lived access tokens.
# HA_CONTAINER: HA's container name if it runs on this NAS (optional).
#HA_URL=http://192.168.1.10:8123
#HA_TOKEN=
#HA_CONTAINER=homeassistant

# --- AdGuard Home ---------------------------------------------------------------
#ADGUARD_URL=http://192.168.1.5:3000
#ADGUARD_USERNAME=
#ADGUARD_PASSWORD=

# --- TrueNAS ----------------------------------------------------------------------
# API key: TrueNAS UI → top-right user icon → API Keys → Add.
#TRUENAS_URL=https://192.168.1.2
#TRUENAS_API_KEY=

# --- Optional ------------------------------------------------------------------------
#WATCHDOG_PASSWORD=          # dashboard basic auth (username "admin")
#HEARTBEAT_URL=              # healthchecks.io ping URL (dead man's switch)
#REMEDIATION_MODE=tiered     # tiered | approve_all | off
